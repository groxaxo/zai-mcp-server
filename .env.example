# ZAI MCP Server - Environment Variables Template
# Copy this file to .env and fill in your actual values

# Required: Your ZAI API key
# Get your API key from: https://z.ai/model-api
ZAI_API_KEY=your-zai-api-key-here

# Optional: Path to server script (for testing)
ZAI_SERVER_PATH=/home/op/zai-mcp-server/src/server.py

# Optional: Enable debug logging
ZAI_DEBUG=0
